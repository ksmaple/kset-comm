# KSet 公共环境变量模板
# Docker 环境版本在本文件统一管理；Maven 依赖版本由 kset-parent/pom.xml 管理。

COMPOSE_PROJECT_NAME=kset-framework

# Nacos
NACOS_IMAGE=nacos/nacos-server:v3.2.0
NACOS_CONSOLE_PORT=8080
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
NACOS_AUTH_TOKEN=a3NldC1sb2NhbC1uYWNvcy1hdXRoLXRva2VuLWNoYW5nZS1tZS0zMi1ieXRlcw==
NACOS_AUTH_IDENTITY_KEY=kset-local-nacos
NACOS_AUTH_IDENTITY_VALUE=kset-local-nacos

# PostgreSQL 17 + pgvector，可选；demo 默认使用 SQLite
POSTGRES_IMAGE=pgvector/pgvector:0.8.2-pg17
POSTGRES_PORT=5432
POSTGRES_DB=kset_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_IMAGE=redis:7.4.9-alpine
REDIS_PORT=6379

# RocketMQ
ROCKETMQ_IMAGE=apache/rocketmq:5.5.0
ROCKETMQ_VERSION=5.5.0
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_BROKER_FAST_PORT=10909
ROCKETMQ_BROKER_IP=127.0.0.1
ROCKETMQ_PROXY_GRPC_PORT=8081
ROCKETMQ_PROXY_REMOTING_PORT=18080

# CAT Server
CAT_SERVER_IP=127.0.0.1
CAT_HTTP_PORT=8088
CAT_TCP_PORT=2280
CAT_JOB_MACHINE=true
CAT_ALERT_MACHINE=true

# CAT 内置 MySQL
CAT_MYSQL_IMAGE=mysql:5.7.37
CAT_MYSQL_PORT=3307
CAT_MYSQL_HOST=mysql
CAT_MYSQL_INTERNAL_PORT=3306
CAT_MYSQL_DATABASE=cat
CAT_MYSQL_USER=root
CAT_MYSQL_PASSWORD=
