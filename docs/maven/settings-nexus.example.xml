<?xml version="1.0" encoding="UTF-8"?>
<!--
  复制为 ~/.m2/settings.xml 的 <servers> 片段，或与现有 settings 合并。
  <server><id> 必须与 kset-parent profile nexus 中 distributionManagement 的 id 一致。
-->
<settings>
    <servers>
        <server>
            <id>kset-nexus-releases</id>
            <username>YOUR_NEXUS_USERNAME</username>
            <password>YOUR_NEXUS_PASSWORD</password>
        </server>
        <server>
            <id>kset-nexus-snapshots</id>
            <username>YOUR_NEXUS_USERNAME</username>
            <password>YOUR_NEXUS_PASSWORD</password>
        </server>
    </servers>
</settings>
